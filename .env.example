# Web3Forms — use the PUBLIC name so the browser can submit (required for form to work)
# Same access key value as in Web3Forms dashboard; recipient email set in dashboard
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Or Resend (optional): comma-separated CONTACT_TO_EMAIL for multiple inboxes
RESEND_API_KEY=
CONTACT_TO_EMAIL=
RESEND_FROM_EMAIL=

# Mailto fallback when no Web3Forms / Resend (set your inbox)
NEXT_PUBLIC_CONTACT_EMAIL=contact@heilhomes.com
