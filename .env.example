# Web3Forms — set ONE of these (same key from Web3Forms dashboard):
# - WEB3FORMS_ACCESS_KEY (server only; browser loads it via /api/contact/web3-key)
# - NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY (inlined at build; optional if server key is set)
WEB3FORMS_ACCESS_KEY=
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Or Resend (optional): comma-separated CONTACT_TO_EMAIL for multiple inboxes
RESEND_API_KEY=
CONTACT_TO_EMAIL=
RESEND_FROM_EMAIL=

# Mailto fallback when no Web3Forms / Resend (set your inbox)
NEXT_PUBLIC_CONTACT_EMAIL=contact@heilhomes.com
