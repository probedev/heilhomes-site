# Contact form — set WEB3FORMS_ACCESS_KEY in Vercel; recipient email in Web3Forms dashboard
WEB3FORMS_ACCESS_KEY=

# Or Resend (optional): comma-separated CONTACT_TO_EMAIL for multiple inboxes
RESEND_API_KEY=
CONTACT_TO_EMAIL=
RESEND_FROM_EMAIL=

# Mailto fallback when no provider above (set your inbox)
NEXT_PUBLIC_CONTACT_EMAIL=contact@heilhomes.com
